# Cloud Storage の OliveYoung ingredients JSON を読むための設定
# このファイルをコピーして .env.local にリネームし、値を設定してください

NEXT_PUBLIC_ING_BUCKET=
NEXT_PUBLIC_ING_PREFIX=oliveyoung/ingredients

# Amazon アソシエイト（商品カードの検索リンクに tag= を付与）
NEXT_PUBLIC_AMAZON_TAG=yourid-22

# 楽天アフィリエイト（検索URLにクエリで付与。キー名は appendRakutenAffiliateParams 内で調整可）
NEXT_PUBLIC_RAKUTEN_AFFILIATE_ID=your-rakuten-id

# Qoo10（検索URLにクエリで付与。キー名は appendQoo10AffiliateParams 内で調整可）
NEXT_PUBLIC_QOO10_AFFILIATE_ID=

# 公開前レポート API（/api/internal/oliveyoung-launch-report）用。未設定時は API は 503
# INTERNAL_LAUNCH_REPORT_SECRET=
